---
import BaseLayout from './BaseLayout.astro'
import Sidebar from '../components/Sidebar.astro'

const { title, description } = Astro.props
---

<BaseLayout title={title} description={description} pageClass="docs-page">
  <div class="docs-layout">
    <Sidebar />
    <div class="docs-content">
      <slot />
    </div>
  </div>
</BaseLayout>

<style>
  .docs-layout {
    display: flex;
    max-width: 1440px;
    margin: 0 auto;
    gap: 0;
  }
  .docs-content {
    flex: 1;
    min-width: 0;
    padding: 3rem 2rem;
    max-width: calc(100% - 280px);
  }
  @media (max-width: 1024px) {
    .docs-layout { flex-direction: column; }
    .docs-content { max-width: 100%; padding: 2rem 1.5rem; }
  }
</style>
